{
  "manifest_version": 3,
  "name": "Glassbox Insight Agent",
  "version": "1.2.1",
  "description": "Privacy-first background analytics and time-tracking for educational environments.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "identity",
    "alarms",
    "tabs",
    "idle",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
